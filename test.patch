+#include "sysinfo.h"
 extern struct proc proc[NPROC];
 
 uint64
@@ -140,4 +141,28 @@ sys_ptree(void)
     }
 
     return count;
+}
+
+uint64
+sys_sysinfo(void)
+{
+  uint64 user_addr;
+  struct sysinfo info;
+
+  argaddr(0, &user_addr);
+
+  info.freemem = getfreemem();
+  info.nproc   = getnproc();
+
+  if(copyout(myproc()->pagetable, user_addr, (char *)&info, sizeof(info)) < 0)
+    return -1;
+  return 0;
+}
+
+uint64
+sys_trace(void) {
+    int mask;
+    argint(0, &mask);
+    myproc()->tracemask = mask;
+    return 0;
 }
